# Neon PostgreSQL connection string
# Get this from https://console.neon.tech after creating a project
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# For local development with Prisma dev server, set this to the direct TCP URL
# DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:51214/template1?sslmode=disable"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
